<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="ThemeOverlay.Material3.BottomNavigationView." parent="Theme.MaterialComponents.DayNight.NoActionBar">

    </style>
    <style name="Base.Theme.CharmReader" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.CharmReader" parent="Base.Theme.CharmReader">
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>




    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">60dp</item> <item name="android:height">32dp</item> <item name="marginHorizontal">4dp</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
    </style>

    <style name="BottomNavText.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="BottomNavText.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>




    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F4F7F9</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/logo2</item>
        <item name="postSplashScreenTheme">@style/Theme.CharmReader</item>
    </style>

    <!-- Para hacer ele jecto de transparentarse -->
    <style name="Theme.Transparent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.15</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Para hacer que a la hora de seleccionar dias y horas salgan del color basico de mi app -->
    <style name="DialogPickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/basico</item>
        <item name="colorAccent">@color/basico</item>

        <item name="android:buttonBarPositiveButtonStyle">@style/PickerButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/PickerButtonStyle</item>
    </style>

    <style name="PickerButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/basico</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>