<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnCloseDialogObra"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            app:tint="#444444" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/btnCloseDialogObra"
            android:layout_marginTop="-10dp"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/ivPortadaDialogObra"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_circle_basico"
                android:padding="20dp"
                android:src="@drawable/ic_libro"
                app:tint="@color/basico" />

            <TextView
                android:id="@+id/tvTituloDialogObra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Título de la Obra"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:text="¿Qué deseas hacer?"
                android:textColor="#757575"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinuarEscribiendo"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="start|center_vertical"
                android:text="Continuar escribiendo"
                android:textColor="#333333"
                android:textSize="16sp"
                app:icon="@drawable/ic_tus_obras"
                app:iconTint="@color/basico"
                app:iconPadding="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModificarMetadatos"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="start|center_vertical"
                android:text="Modificar metadatos"
                android:textColor="#333333"
                android:textSize="16sp"
                app:icon="@drawable/ic_settings"
                app:iconTint="@color/basico"
                app:iconPadding="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCambiarEstado"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="start|center_vertical"
                android:text="Marcar como finalizado"
                android:textColor="#333333"
                android:textSize="16sp"
                app:icon="@drawable/ic_check_circle"
                app:iconTint="@color/basico"
                app:iconPadding="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDescargarLibro"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="start|center_vertical"
                android:text="Descargar libro"
                android:textColor="#333333"
                android:textSize="16sp"
                app:icon="@android:drawable/stat_sys_download"
                app:iconTint="@color/basico"
                app:iconPadding="16dp" />

        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>