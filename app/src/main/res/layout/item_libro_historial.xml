<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <androidx.cardview.widget.CardView
            android:layout_width="55dp"
            android:layout_height="80dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <ImageView
                android:id="@+id/ivPortadaHistorial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_libro" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIBRO FINALIZADO"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvTituloHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título del Libro"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvFechasHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="01/01/2026 - 15/01/2026"
                android:textColor="#757575"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFC107" />

                <TextView
                    android:id="@+id/tvMediaNumerica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0.0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFC107" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:background="#DDDDDD"
                    android:layout_marginHorizontal="8dp"/>

                <TextView
                    android:id="@+id/tvSesionesHistorial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 sesiones"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>