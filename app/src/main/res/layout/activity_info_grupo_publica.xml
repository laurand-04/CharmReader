<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btnBackInfoPublica"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="#1A1A1A" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFotoPerfil"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@color/basico"
                app:layout_constraintStart_toEndOf="@id/btnBackInfoPublica"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:id="@+id/ivDetalleGrupoFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_people" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutTextos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/containerAcciones"
                app:layout_constraintStart_toEndOf="@id/cardFotoPerfil"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvNombreDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Nombre del Grupo"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUbicacionDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubicación"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/containerAcciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGestionarPublico"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestionar"
                    android:textColor="@color/basico"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:icon="@drawable/ic_gavel"
                    app:iconSize="18dp"
                    app:iconTint="@color/basico" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccionUnirse"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unirse"
                    android:textColor="@color/basico"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconSize="18dp"
                    app:iconTint="@color/basico" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccionAbandonar"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salir"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconSize="18dp"
                    app:iconTint="#E53935" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sobre este grupo"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvDescDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cargando descripción..."
                android:lineSpacingExtra="4dp"
                android:textColor="#444444"
                android:textSize="15sp" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@android:color/transparent"
                app:tabIndicatorColor="@color/basico"
                app:tabSelectedTextColor="@color/basico"
                app:tabTextColor="#999999"
                app:tabIndicatorFullWidth="false"
                app:tabRippleColor="@android:color/transparent"/>

            <LinearLayout
                android:id="@+id/layoutEmptyGrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/ivEmptyIcon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_libro"
                    app:tint="#D1D1D1" />
                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sin datos"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvEmptySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay nada que mostrar por ahora."
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:textAlignment="center" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLibrosLeidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComentariosGrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>