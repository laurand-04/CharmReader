<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F0F4F8"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PANEL DE ADMINISTRACIÓN"
    android:textColor="#37474F"
    android:textSize="12sp"
    android:textStyle="bold"
    android:letterSpacing="0.1"
    android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvNombreGestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargando grupo..."
        android:textColor="#102A43"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvIdGestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID: --"
        android:textColor="#627D98"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#D9E2EC"
        android:layout_marginVertical="20dp"/>

    <Button
        android:id="@+id/btnVerMiembros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestionar Miembros"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#243B53"/>

    <Button
        android:id="@+id/btnEliminarGrupo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Eliminar Grupo"
        android:backgroundTint="#D32F2F" />

</LinearLayout>