<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD"
    tools:context=".ui.priv.fragmentView.TusObrasFragment">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearchObras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        android:background="@color/white">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewObras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:iconifiedByDefault="false"
            app:queryHint="Busca tu obra..."
            android:background="@color/white" />
    </androidx.cardview.widget.CardView>

    <HorizontalScrollView
        android:id="@+id/scrollFiltersObras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardSearchObras"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFiltersObras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"> <com.google.android.material.chip.Chip
            android:id="@+id/chipTodosObras"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Todos" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSinFinalizarObras"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin finalizar" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFinalizadosObras"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finalizados" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerObras"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/scrollFiltersObras"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/layoutEmptyTusObras"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_libro"
            app:tint="#D1D1D1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Aún no has creado ninguna obra"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Toca el botón + para empezar a escribir"
            android:textColor="#757575"
            android:textSize="14sp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_obra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:backgroundTint="@color/basico" />

</RelativeLayout>